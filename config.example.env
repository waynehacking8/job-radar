# job-radar configuration — copy to `config.env` and fill in.
#   cp config.example.env config.env  &&  $EDITOR config.env

# --- Email delivery (Gmail) -------------------------------------------------
# Use a Gmail *App Password*, NOT your normal password. Requires 2FA enabled.
# Create one at: https://myaccount.google.com/apppasswords
# Leave unset to just print the digest (useful for a local dry run).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=
EMAIL_TO=you@gmail.com

# --- Tuning (optional) ------------------------------------------------------
SEEN_TTL_DAYS=30          # don't re-show a job seen within this many days
JOB_RADAR_MAX_ITEMS=60    # cap digest size

# Server-side narrowing terms POSTed to Workday (comma-separated):
# JOB_RADAR_SEARCH_TERMS=machine learning,deep learning,LLM,GPU,inference,CUDA,PyTorch,MLOps

# Location gate (regex). Default = Taiwan only. Widen to include remote/overseas:
# JOB_RADAR_LOCATION_RE=taiwan|taipei|hsinchu|remote|singapore
